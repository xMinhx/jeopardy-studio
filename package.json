{
  "name": "jeopardy-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Dual-window Jeopardy-style scoreboard assistant for hosts.",
  "author": "Minh Truong",
  "type": "module",
  "main": "electron/main/index.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5174 && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .\"",
    "build:renderer": "vite build",
    "build": "vite build && electron-builder -c",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest --config vite.config.ts --run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.minh.quizshow",
    "productName": "Jeopardy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "electron"
    ],
    "win": {
      "icon": "public/assets/icon.png",
      "target": "nsis"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.10.19",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.3",
    "wait-on": "^8.0.1"
  }
}
